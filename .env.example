RAG_APP_NAME=Local Enterprise RAG
RAG_ENVIRONMENT=local
RAG_DEBUG=false
RAG_DATA_DIR=./data
RAG_DATABASE_URL=sqlite:///./data/app.db
RAG_REDIS_URL=redis://localhost:6379/0
RAG_CELERY_TASK_ALWAYS_EAGER=true
RAG_EXTERNAL_ENV_FILE=
RAG_MAX_UPLOAD_MB=50
RAG_VECTOR_STORE_BACKEND=auto
RAG_EMBEDDING_PROVIDER=mock
RAG_EMBEDDING_MODEL=mock-hash-embedding
RAG_EMBEDDING_DIMENSION=384
RAG_DASHSCOPE_API_KEY=
RAG_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
RAG_RERANK_PROVIDER=lexical
RAG_RERANK_MODEL=
RAG_RERANK_API_KEY=
RAG_RERANK_BASE_URL=https://dashscope.aliyuncs.com
RAG_RERANK_ENDPOINT_PATH=/compatible-api/v1/reranks
RAG_RERANK_TIMEOUT_SECONDS=10
RAG_GENERATION_PROVIDER=mock
RAG_CHAT_MODEL=mock-local-answerer
RAG_OPENAI_API_KEY=
RAG_OPENAI_BASE_URL=
